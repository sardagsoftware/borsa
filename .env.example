# 🛡️ AILYDIAN AI LENS TRADER — Environment Variables
# COPY THIS FILE TO .env.local AND FILL IN YOUR VALUES

# ═══════════════════════════════════════════════════════
# SITE CONFIGURATION
# ═══════════════════════════════════════════════════════
SITE_URL=https://borsa.ailydian.com
NEXT_PUBLIC_APP_NAME=AiLydian Borsa - Trader
NODE_ENV=production

# ═══════════════════════════════════════════════════════
# DATABASE & REDIS
# ═══════════════════════════════════════════════════════
DATABASE_URL="postgresql://username:password@localhost:5432/ailydian_trader"
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ═══════════════════════════════════════════════════════
# AUTHENTICATION
# ═══════════════════════════════════════════════════════
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"
ENCRYPTION_KEY="your-encryption-key-for-api-keys-32-chars"

# ═══════════════════════════════════════════════════════
# TRADING APIs
# ═══════════════════════════════════════════════════════
COINMARKETCAP_API_KEY="your-coinmarketcap-api-key"

# Binance Futures (Primary)
BINANCE_API_KEY=
BINANCE_API_SECRET=
BINANCE_TESTNET=true
BINANCE_BASE=https://fapi.binance.com
BINANCE_WSS=wss://fstream.binance.com/stream

# Other Exchanges (Optional)
BYBIT_API_KEY=
BYBIT_API_SECRET=
OKX_API_KEY=
OKX_API_SECRET=
KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ═══════════════════════════════════════════════════════
# AI & LLM
# ═══════════════════════════════════════════════════════
OPENAI_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
EMBEDDINGS_PROVIDER=hf
EMBEDDINGS_MODEL=bge-m3
VECTOR_BACKEND=pgvector

# ═══════════════════════════════════════════════════════
# BOT CONFIGURATION
# ═══════════════════════════════════════════════════════
BOT_ENABLED=true
BOT_MODE=semi
REQUIRE_OPTIN_FOR_LIVE=true
GLOBAL_KILL_SWITCH=false
ALLOW_PAPER_TRADING=true

# Risk Guardrails
MAX_DAILY_LOSS_USD=600
MAX_SINGLE_TRADE_RISK_PCT=0.8
MAX_CONCURRENT_POS=5
SPREAD_MAX_BPS=15
MIN_ORDERBOOK_DEPTH_USD=150000

# ═══════════════════════════════════════════════════════
# SECURITY CENTER
# ═══════════════════════════════════════════════════════
SEC_CENTER_ENABLE=true
SEC_SCAN_CRON="*/30 * * * *"
WAF_PROVIDER=cloudflare
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=ailydian-trader
PROM_PUSHGATEWAY_URL=

# Security Alerts
ALERT_SLACK_WEBHOOK=
ALERT_TELEGRAM_BOT_TOKEN=
ALERT_TELEGRAM_CHAT_ID=
ALERT_WEBHOOK_SECRET=

# Supply Chain Security
SIGSTORE_ENABLE=true
SLSA_LEVEL=3
SBOM_ENABLE=true

# Canary Tokens
CANARYTOKENS_ENABLE=true
CANARY_WEBHOOK_URL=

# Security Feeds
CISA_KEV_FEED=https://www.cisa.gov/sites/default/files/feeds/known_exploited_vulnerabilities.json
NVD_CVE_FEED=https://services.nvd.nist.gov/rest/json/cves/2.0?lastModStartDate=NOW-1d
GHSA_FEED=https://github.com/advisories?query=type%3Areviewed
NPM_ADVISORY_ENABLE=true

# DNS & TLS Monitoring
DNS_MONITOR_ENABLE=true
TLS_REPORT_ENABLE=true
TYPO_SQUAT_MONITOR=true

# Key Management
KMS_OR_VAULT_PROVIDER=kv
VAULT_NAMESPACE=exkeys

# ═══════════════════════════════════════════════════════
# OWNERSHIP & COPYRIGHT
# ═══════════════════════════════════════════════════════
OWNERSHIP_LEGAL_NAME="Emrah Şardağ"
OWNERSHIP_COPYRIGHT="© Emrah Şardağ. All rights reserved."
OWNERSHIP_CONTACT="legal@ailydian.com"

# ═══════════════════════════════════════════════════════
# CLOUDFLARE INTEGRATION
# ═══════════════════════════════════════════════════════
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_ZONE_ID=

# ═══════════════════════════════════════════════════════
# SIGSTORE & CI/CD
# ═══════════════════════════════════════════════════════
SIGSTORE_IDENTITY=github.com/sardagsoftware/ailydian-borsa-trader
SIGSTORE_FULCIO_URL=https://fulcio.sigstore.dev
SIGSTORE_REKOR_URL=https://rekor.sigstore.dev
GITHUB_TOKEN=
VERCEL_TOKEN=

# ═══════════════════════════════════════════════════════
# SOC & MITRE ATT&CK
# ═══════════════════════════════════════════════════════
SOC_ENABLE=true
SOC_RETENTION_DAYS=30
SOC_ALERT_THRESHOLD=high
SOC_PLAYBOOK_MODE=semi
SOC_CORRELATION_WINDOW_M=45
MITRE_KB_VERSION=13
AI_DETECT_PROVIDER=openai
AI_DETECT_MODEL=gpt-4o-mini
ATTACK_FEEDS=cloudflare,vercel,waf,secscan,osint,anomaly
TTP_SUPPRESS_MINUTES=120
SOC_SLACK_CHANNEL=#soc-alerts
SOC_TELEGRAM_CHAT_ID=
KIBANA_URL=

# ═══════════════════════════════════════════════════════
# SOC++ (NAVIGATOR, SIGMA, YARA, IOC, STIX)
# ═══════════════════════════════════════════════════════
SOC_NAVIGATOR_ENABLE=true
SOC_SIGMA_ENABLE=true
SOC_YARA_ENABLE=true
SOC_TAXII_ENABLE=true
IOC_ENRICH_ENABLE=true

# IOC Enrichment
ABUSEIPDB_KEY=
OTX_API_KEY=
VIRUSTOTAL_API_KEY=

# TAXII
TAXII_SERVER_URL=
TAXII_COLLECTION_ID=
TAXII_USER=
TAXII_PASS=

# YARA & SIGMA
YARA_RULES_PATH=./security/yara
YARA_MAX_MB=25
SIGMA_RULES_PATH=./security/sigma
SIGMA_BACKEND=generic
SIGMA_TIME_WINDOW_M=60

# Navigator Export
NAV_EXPORT_BUCKET_URL=
NAV_EXPORT_SIGNING_SECRET=

# ═══════════════════════════════════════════════════════
# WEB3 WALLET CONNECT
# ═══════════════════════════════════════════════════════
NEXT_PUBLIC_WC_PROJECT_ID=
WALLETCONNECT_PROJECT_ID=

# SIWE (Sign-In with Ethereum)
SIWE_DOMAIN=borsa.ailydian.com
SIWE_STMT=Ailydian Trader'a güvenli giriş
SIWE_EXP_MIN=30
NEXT_PUBLIC_SIWE_STMT=Ailydian Trader'a güvenli giriş

# EVM Chains (comma-separated chain IDs)
EVM_ENABLED_CHAINS=1,56,137,43114
EVM_DEFAULT_CHAIN=56

# ═══════════════════════════════════════════════════════
# MULTI-ACCOUNT & VAULT
# ═══════════════════════════════════════════════════════
VAULT_PROVIDER=kv
VAULT_KV_NAMESPACE=exkeys
VAULT_ENCRYPTION_KEY=
MULTI_ACCOUNT=true
MAX_ACCOUNTS_PER_USER=5

# ═══════════════════════════════════════════════════════
# TRADING PARAMETERS
# ═══════════════════════════════════════════════════════
# Regime Detection
LEAD_ASSETS=BTCUSDT,ETHUSDT
REGIME_LOOKBACK=1440
VOL_LOOKBACK=240
SQUEEZE_WINDOW=20
BREAKOUT_WINDOW=55

# Universe Selection
COINGECKO_TOP_N=100
UNIVERSE_REFRESH_M=60

# ═══════════════════════════════════════════════════════
# FEATURE FLAGS & DEPLOYMENT
# ═══════════════════════════════════════════════════════
FEATURE_FLAGS_JSON='{"newSOR":true,"greeksHedge":true,"ultraMicro":true,"multiAccount":true,"mobileSync":true}'
CANARY_PERCENT=10
BLUE_GREEN_ENABLED=true
DEPLOY_STRATEGY=canary

# ═══════════════════════════════════════════════════════
# DISASTER RECOVERY & SNAPSHOTS
# ═══════════════════════════════════════════════════════
SNAPSHOT_BUCKET_URL=
SNAPSHOT_SIGNING_SECRET=
SNAPSHOT_RETENTION_DAYS=30

# ═══════════════════════════════════════════════════════
# MOBILE & DEEP LINKS
# ═══════════════════════════════════════════════════════
MOBILE_DEEP_LINK=ailens://trade
EXPO_PROJECT_ID=
EXPO_EAS_TOKEN=
MOBILE_API_VERSION=v1

# ═══════════════════════════════════════════════════════
# COMPLIANCE & KYC
# ═══════════════════════════════════════════════════════
COMPLIANCE_REGION_HINT=TR
KYC_SIGNAL_PROVIDER=off
COMPLIANCE_ENABLED=false

# ═══════════════════════════════════════════════════════
# PERFORMANCE & LIMITS
# ═══════════════════════════════════════════════════════
WS_MAX_CONNECTIONS=1000
API_RATE_LIMIT_RPM=6000
QUEUE_MAX_JOBS=10000
CACHE_TTL_SECONDS=300

# ═══════════════════════════════════════════════════════
# SECURITY SETTINGS
# ═══════════════════════════════════════════════════════
API_KEY_ROTATION_HOURS=168
SESSION_ENCRYPTION_KEY=
ADMIN_WHITELIST_IPS=
