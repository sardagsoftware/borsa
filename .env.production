# Production Environment Variables for Vercel
NODE_ENV=production
NEXTAUTH_URL=https://borsa.ailydian.com
NEXTAUTH_SECRET=prod_ailydian_secret_key_ultra_secure_2025

# Database Configuration (Production)
DATABASE_URL="postgresql://prod_user:prod_pass@db-host:5432/ailydian_borsa"

# Redis Configuration (Production)  
REDIS_URL="rediss://redis-host:6380"

# Production API Keys
BINANCE_API_KEY=REPLACE_WITH_REAL_BINANCE_API_KEY
BINANCE_SECRET_KEY=REPLACE_WITH_REAL_BINANCE_SECRET_KEY
COINGECKO_API_KEY=REPLACE_WITH_REAL_COINGECKO_API_KEY

# OpenAI Configuration
OPENAI_API_KEY=REPLACE_WITH_REAL_OPENAI_API_KEY

# CAPTCHA Configuration (Production)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=REPLACE_WITH_REAL_RECAPTCHA_SITE_KEY
RECAPTCHA_SECRET_KEY=REPLACE_WITH_REAL_RECAPTCHA_SECRET_KEY
NEXT_PUBLIC_CLOUDFLARE_TURNSTILE_SITE_KEY=REPLACE_WITH_REAL_TURNSTILE_SITE_KEY
CLOUDFLARE_TURNSTILE_SECRET_KEY=REPLACE_WITH_REAL_TURNSTILE_SECRET_KEY

# Upstash Redis (Production)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=REPLACE_WITH_REAL_UPSTASH_TOKEN

# Production Settings
FAST_REFRESH=false
LOG_LEVEL=info
PINO_LOG_LEVEL=info

# PRO+ Features (Production)
PRO_ENCRYPTION_KEY=prod_encryption_key_32_chars_secure
PRO_HMAC_SECRET=prod_hmac_secret_key_for_production

# Health Check
HEALTH_CHECK_TOKEN=ailydian_health_prod_2025

# Wallet Configuration (Production)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=2f05a7e6e4adfb59423ccbc7832b4e5d
NEXT_PUBLIC_ENABLE_TESTNETS=false
NEXT_PUBLIC_APP_NAME=AILYDIAN
NEXT_PUBLIC_APP_DESCRIPTION=AI Lens Trader - Professional Crypto Trading Platform
NEXT_PUBLIC_APP_URL=https://borsa.ailydian.com
NEXT_PUBLIC_APP_ICON=https://borsa.ailydian.com/logo.png

# SIWE Configuration
SIWE_SECRET=ailydian_siwe_prod_secret_key_for_authentication_2025

# Security Configuration (Production)
SEC_CENTER_ENABLE=true
SEC_SCAN_CRON="*/30 * * * *"
WAF_PROVIDER=cloudflare
SOC_ENABLE=true
SOC_RETENTION_DAYS=90
SOC_ALERT_THRESHOLD=medium

# Monitoring (Production)
PROMETHEUS_ENABLED=true
OTEL_ENABLED=true

# Legal & Ownership
OWNERSHIP_LEGAL_NAME="Emrah Şardağ"
OWNERSHIP_COPYRIGHT="© Emrah Şardağ. All rights reserved."
OWNERSHIP_CONTACT="legal@ailydian.com"
