  "related_applications": [],
  "prefer_related_applications": false,
  "edge_side_panel": {
    "preferred_width": 400
  },
  "screenshots": [
    {
      "src": "/screenshots/desktop-1.png",
      "sizes": "1280x720",
      "type": "image/png",
      "platform": "wide",
      "label": "Ana dashboard ekranı"
    },
    {
      "src": "/screenshots/mobile-1.png",
      "sizes": "390x844",
      "type": "image/png",
      "platform": "narrow",
      "label": "Mobil trading ekranı"
    }
  ],
  "share_target": {
    "action": "/tr/dashboard/share",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "files",
          "accept": ["image/*", ".csv", ".json"]
        }
      ]
    }
  },
  "protocol_handlers": [
    {
      "protocol": "web+crypto",
      "url": "/tr/dashboard/crypto?symbol=%s"
    }
  ]
}
